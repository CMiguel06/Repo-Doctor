{
  "name": "repo-doctor-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Repository health analysis for developers, students and technical reviewers.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @repo-doctor/web run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "dev:web": "npm --workspace @repo-doctor/web run dev",
    "build:web": "npm --workspace @repo-doctor/web run build",
    "start:web": "npm --workspace @repo-doctor/web run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.7.2"
  }
}
